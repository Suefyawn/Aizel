# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# IDE
.idea
.vscode

# Claude Code local settings (per-user, do NOT commit).
.claude/settings.local.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/worktrees/

# Inventory scratch — raw HTML dumps and intermediate JSON the importer
# writes locally. The README and the importer script itself ARE checked in.
inventory/_*.html
inventory/_*.json
inventory/_*.mjs
inventory/_*.png
inventory/*.csv

# Local rebrand history note (one-off — references the old YellowPink SHA)
.git-history-note.txt

*.lnk
