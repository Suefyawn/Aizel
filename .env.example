# ─── Supabase ────────────────────────────────────────────────────────────────
# Public values — safe to expose to the browser (anon key relies on RLS).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin & staff auth ──────────────────────────────────────────────────────
# Legacy owner password (single-user). Used by src/proxy.ts middleware
# and src/lib/staff-auth.ts. Rotate any time it might have leaked.
ADMIN_PASSWORD=

# HMAC secret used to sign staff session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STAFF_SESSION_SECRET=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
# Where to send internal notifications (new orders, low-stock alerts).
OWNER_EMAIL=
# Verified "from" domain in Resend. Defaults to orders@aizel.co.uk.
EMAIL_FROM="Aizel Orders <orders@aizel.co.uk>"

# ─── Site origin ─────────────────────────────────────────────────────────────
# Public site origin used to build absolute URLs (OG images, emails, etc).
NEXT_PUBLIC_SITE_URL=https://aizel.co.uk

# ─── Payments — Stripe (recommended UK option) ───────────────────────────────
# Get from https://dashboard.stripe.com/apikeys. Test keys start with "sk_test_"
# and "pk_test_"; live keys start with "sk_live_" and "pk_live_".
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Set after creating a webhook endpoint in the Stripe dashboard pointing at
# https://aizel.co.uk/api/payments/stripe/webhook.
STRIPE_WEBHOOK_SECRET=

# ─── Klarna on-site messaging (PDP "3 instalments of £X" widget) ─────────────
# Apply at https://klarna.com/uk/business/. Set your client ID here to enable
# the Klarna instalment line under the PDP price. If unset, the PDP renders
# without Klarna messaging — we never claim a payment method is available
# without operator confirmation.
NEXT_PUBLIC_KLARNA_CLIENT_ID=

# ─── Meta (Facebook) Pixel ───────────────────────────────────────────────────
# Create the pixel in Meta Events Manager (business.facebook.com/events_manager)
# and paste its 15-digit ID here. The loader fires only when this is set AND
# the visitor has granted MARKETING consent (analytics consent is not enough —
# Meta Pixel is explicitly a retargeting tool per ICO cookie classification).
NEXT_PUBLIC_META_PIXEL_ID=

# ─── A/B experiments ─────────────────────────────────────────────────────────
# Each experiment is one env var of the form
#   NEXT_PUBLIC_AB_<KEY>="variant:weight,variant:weight"
# Weights are relative — "A:50,B:50" is 50/50, "A:1,B:3" is 25/75. Variants
# are reported to GA4 / Plausible / Meta Pixel as `experiment_assigned` events
# so the analyst can segment trends + funnels downstream. See
# src/lib/hooks/useAbTest.ts for the supported experiment keys + consumption
# pattern. Leave any of these blank to ship only the control branch.
NEXT_PUBLIC_AB_HERO_HEADLINE=
NEXT_PUBLIC_AB_PDP_CTA=
NEXT_PUBLIC_AB_QUIZ_OPENER=

# ─── UK postcode lookup at checkout ──────────────────────────────────────────
# Loqate (formerly Addressy) — apply at https://www.loqate.com/en-gb/.
# Ideal Postcodes (alternative) — https://ideal-postcodes.co.uk/.
# When set, checkout shows a "Find address" button next to the postcode field
# and the operator's chosen address pre-fills line1 + city. When unset, the
# postcode is captured as plain text — no fake matches, no broken lookup.
# Server-side only — never expose this key to the browser.
LOQATE_API_KEY=

# ─── Payments — PayPal (optional, alongside Stripe) ──────────────────────────
# Get from https://developer.paypal.com/dashboard.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# 'live' or 'sandbox' — controls which PayPal API base the SDK targets.
PAYPAL_ENVIRONMENT=sandbox

# ─── Courier webhook ─────────────────────────────────────────────────────────
# Shared secret expected as `Authorization: Bearer <secret>` on
# POST /api/couriers/webhook. Pick anything random.
COURIER_WEBHOOK_SECRET=

# ─── Abandoned-cart cron (optional) ──────────────────────────────────────────
# Vercel injects this header for scheduled invocations. Pick anything random.
CRON_SECRET=
# Discount code emailed in the 72-hour "last chance" tier.
ABANDONED_CART_DISCOUNT_CODE=COMEBACK10
ABANDONED_CART_DISCOUNT_PCT=10

# ─── Rate limiting (optional, recommended) ───────────────────────────────────
# Upstash Redis-backed rate limiting for auth + checkout endpoints.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── eBay inventory importer (scripts/import-ebay-inventory.mjs) ─────────────
# Aizel's initial catalogue lives on eBay. The importer either reads a CSV
# export from the eBay seller dashboard or scrapes a public seller URL.
# Used only by `npm run import:ebay`. Not consumed at runtime.

# Path or URL to the CSV the importer should read. Drop the file in
# `./inventory/ebay.csv` and leave this unset to use the default.
EBAY_INVENTORY_CSV=

# Public eBay seller URL (e.g. https://ebay.co.uk/usr/aizel-uk). Optional
# alternative to the CSV — the importer will fetch listings from this URL.
EBAY_SELLER_URL=

# Importer tunables.
EBAY_IMPORT_DRY_RUN=false
EBAY_IMPORT_BATCH_SIZE=25
EBAY_IMPORT_BUCKET=product-images

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Set to your Plausible domain to enable server-free events tracking.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# GA4 Measurement ID. When set, the storefront loads gtag.js (consent-gated)
# and every commerce event from lib/analytics.ts (view_item, add_to_cart,
# begin_checkout, purchase, search, sign_up) flows to GA4 automatically.
# Find it in GA4 Admin → Property → Data Streams → Web → Measurement ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Search Console URL-prefix verification (optional — domain-property DNS
# verification is preferred). Paste the value from the meta-tag verification
# method — just the content="" string, without quotes.
GOOGLE_SITE_VERIFICATION=

# ─── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=aizel
SENTRY_AUTH_TOKEN=

# ─── Twilio SMS notifications (optional) ─────────────────────────────────────
# Sends customer-facing SMS at order placed / shipped / delivered. Skip
# entirely if you only want email — every Twilio send is gated on these
# being set, so missing keys never trigger an error.
#
# Get from https://console.twilio.com.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Either a purchased UK number (recommended for reliability):
TWILIO_FROM_NUMBER=
# Or a Messaging Service SID (preferred — handles routing + UK Sender ID):
TWILIO_MESSAGING_SERVICE_SID=

# ─── WhatsApp deep-link (optional) ───────────────────────────────────────────
# Merchant's WhatsApp Business number in international E.164 format WITHOUT
# the leading "+" and without spaces/dashes. UK example: 447123456789.
# When set, storefront and admin render "Chat on WhatsApp" buttons that
# open wa.me/<number> with a pre-typed message.
NEXT_PUBLIC_WHATSAPP_NUMBER=
